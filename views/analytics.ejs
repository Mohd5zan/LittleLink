<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Little URLs - Analytics</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/analytics.css">
</head>

<body>

    <div class="position-absolute top-0 end-0 p-4">
        <a href="/userpage" class="btn btn-outline-light">
            <i class="bi bi-arrow-left me-1"></i>
            Back
        </a>
    </div>

    <div class="analytics-container">

        <div class="analytics-card">

            <div class="header-section">

                <div class="brand">
                    <div class="logo">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>

                    <div>
                        <h4 class="mb-0">Analytics Dashboard</h4>
                        <small>Track your shortened URLs</small>
                    </div>
                </div>

                <div class="stats-box">
                    <i class="bi bi-link-45deg"></i>
                    <span>Total URLs:
                        <strong>
                            <%= urls.length %>
                        </strong>
                    </span>
                </div>

            </div>

            <div class="table-responsive">

                <table class="table custom-table align-middle">

                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Original URL</th>
                            <th>Redirect URL</th>
                            <th>Click Time</th>
                            <th>No. of Clicks</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% urls.forEach((url,index)=> { %>

                            <tr>

                                <td>
                                    <%= index + 1 %>
                                </td>

                                <td class="text-truncate-url">
                                    <%= url.orgurl %>
                                </td>

                                <td>
                                    <a href="<%= BASE_URL %>/url/<%= url.shortid %>" target="_blank">
                                        <%= BASE_URL %>/url/<%= url.shortid %>
                                    </a>
                                </td>

                                <td>
                                    <a href="/url/analytics/<%= url.shortid %>">
                                        View History
                                    </a>
                                </td>

                                <td>
                                    <span class="click-badge">
                                        <%= url.visithistory.length %>
                                    </span>
                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

</html>