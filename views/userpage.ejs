<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Little URLs</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/userpage.css">
</head>

<body>
    <div class="position-absolute top-0 end-0 p-4">
        <form action="/logout" method="POST">
            <a href="/url/analytics" class="btn analytics-btn">
                <i class="bi bi-bar-chart-line-fill me-2"></i>
                Analytics
            </a>
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-box-arrow-right me-1"></i>
                Logout
            </button>
        </form>
    </div>
    <div class="hero-card">

        <div class="hero-left">

            <div class="brand">
                <div class="logo">
                    <i class="bi bi-link-45deg"></i>
                </div>

                <div>
                    <h5 class="mb-0">Little URLs</h5>
                    <small>Smart links, made simple</small>
                </div>
            </div>

            <div class="hero-content">
                <h1>Transform Long URLs Into Smart Short Links</h1>

                <p>
                    Create clean, memorable links in seconds.
                    Track clicks, manage URLs and share links
                    effortlessly from one dashboard.
                </p>

                <div class="feature-list">

                    <div class="feature">
                        <i class="bi bi-lightning-charge-fill"></i>
                        Instant URL shortening
                    </div>

                    <div class="feature">
                        <i class="bi bi-bar-chart-fill"></i>
                        Click analytics
                    </div>

                    <div class="feature">
                        <i class="bi bi-shield-check"></i>
                        Secure redirects
                    </div>

                </div>
            </div>

        </div>

        <div class="hero-right">

            <div class="form-card">

                <span class="badge-custom">
                    <i class="bi bi-stars"></i>
                    Create New Link
                </span>

                <h2>Shorten a URL</h2>

                <p class="text-muted-custom">
                    Paste your long URL below and generate a short,
                    shareable link instantly.
                </p>

                <form action="/url/generate" method="POST">

                    <div class="mb-4">
                        <label class="form-label">
                            Destination URL
                        </label>

                        <input type="url" name="url" class="form-control form-control-lg"
                            placeholder="https://example.com/very-long-url" required>
                    </div>

                    <button type="submit" class="btn btn-create w-100">
                        <i class="bi bi-magic me-2"></i>
                        Generate Short URL
                    </button>

                </form>

                <% if (typeof shortUrl !=='undefined' && shortUrl) { %>
                    <div class="mt-4">
                        <label class="form-label">Generated URL</label>

                        <div class="input-group">
                            <input type="text" id="shortUrl" class="form-control" value="<%= shortUrl %>" readonly>

                            <button class="btn btn-success" type="button" onclick="copyUrl()">
                                <i class="bi bi-clipboard"></i>
                                Copy
                            </button>
                        </div>
                    </div>
                    <% } %>

            </div>

        </div>

    </div>
    <script src="/javascripts/userpage.js"></script>
</body>

</html>