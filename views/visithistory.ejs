<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Little URLs - Visit History</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/visithistory.css">
</head>

<body>

    <div class="position-absolute top-0 end-0 p-4">
        <a href="/url/analytics" class="btn btn-back">
            <i class="bi bi-arrow-left me-2"></i>
            Back
        </a>
    </div>

    <div class="history-container">

        <div class="history-card">

            <div class="header-section">

                <div class="brand">
                    <div class="logo">
                        <i class="bi bi-clock-history"></i>
                    </div>

                    <div>
                        <h3 class="mb-1">Visit History</h3>
                        <small>Detailed click analytics</small>
                    </div>
                </div>

                <div class="click-counter">
                    <i class="bi bi-cursor-fill"></i>
                    <span>
                        Total Clicks:
                        <strong>
                            <%= url.visithistory.length %>
                        </strong>
                    </span>
                </div>

            </div>

            <div class="url-box">
                <div>
                    <span class="label">Original URL</span>
                    <p>
                        <%= url.orgurl %>
                    </p>
                </div>
            </div>

            <div class="table-responsive">

                <table class="table custom-table">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Visit Time</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if(url.visithistory.length===0){ %>

                            <tr>
                                <td colspan="2" class="text-center">
                                    No visits recorded yet.
                                </td>
                            </tr>

                        <% } %>

                        <% url.visithistory.forEach((visit,index)=>{ %>

                            <tr>

                                <td>
                                    <%= index + 1 %>
                                </td>

                                <td>
                                    <%= new Date(visit.timestamp).toLocaleString() %>
                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

</html>